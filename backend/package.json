{
  "name": "studysmart-ai-backend",
  "version": "1.0.0",
  "description": "Backend for StudySmart AI application",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:all": "start cmd /k \"cd backend && npm run dev\" & start cmd /k \"cd . && npm run dev\"",
    "build": "tsc",
    "start": "node dist/server.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.0",
    "@types/pdf-parse": "^1.1.4",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
